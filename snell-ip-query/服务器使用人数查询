    if "china broadnet" in lower or "broadcast" in lower:
        return "广电"
    if "tencent" in lower:
        return "腾讯云"
    if "dmit" in lower:
        return "DMIT云"
    if "ovh" in lower:
        return "OVH"
    if "digitalocean" in lower:
        return "DigitalOcean"
    if "vultr" in lower:
        return "Vultr"
    if "linode" in lower or "akamai" in lower:
        return "Linode"
    if "oracle" in lower:
        return "甲骨文云"
    if "alibaba" in lower or "aliyun" in lower:
        return "阿里云"
    if "huawei" in lower:
        return "华为云"
    if "baidu" in lower:
        return "百度云"
    if "amazon" in lower or "aws" in lower:
        return "亚马逊云"
    if "cloudflare" in lower:
