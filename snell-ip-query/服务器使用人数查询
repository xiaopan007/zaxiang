def main():
    if len(sys.argv) > 1 and sys.argv[1] == "--scan-new-source-notify":
        port = get_snell_port()
        if not port:
            print("未能自动识别 Snell 端口。可用 SNELL_PORT=端口 手动指定。", file=sys.stderr)
            return 2
        ok, message = scan_new_source_notifications(port)
        print(message)
        return 0 if ok else 1

    port = get_snell_port()
    if not port:
        print("未能自动识别 Snell 端口。可用 SNELL_PORT=端口 手动指定。", file=sys.stderr)
        print("例如：SNELL_PORT=49376 /root/服务器使用人数查询", file=sys.stderr)
        return 2

    if not sys.stdin.isatty():
        print_summary(port)
        return 0

    ensure_shortcut_installed()
    return show_menu(port)


def print_summary(port):
    details = get_visible_ip_details(port)

    shanghai_tz = timezone(timedelta(hours=8))
    now = datetime.now(shanghai_tz).strftime("%Y-%m-%d %H:%M:%S")
    print("查询时间：" + now)
    print("Snell 端口：" + str(port))
    print("当前公网 IP 数：" + str(len(details)))
    print()
    if not details:
        print("0")
        return

    for line in format_query_detail_lines(details):
        print(line)


def refresh_screen():
    if sys.stdout.isatty() and os.environ.get("TERM") and shutil.which("clear"):
        subprocess.call(["clear"], stderr=subprocess.DEVNULL)
    else:
        print()


def show_menu(port):
    while True:
        print()
        print("1. 查询 IP 连接情况")
        print("2. 按 IP 封禁")
        print("3. 解除 IP 封禁")
        print("4. 新来源自动通知")
        print("0. 退出脚本")
        print("00. 更新脚本")
        choice = input("请选择：").strip().lower()

        if choice == "00":
            return self_update()
        if choice in ("0", "q", "quit", "exit"):
            refresh_screen()
            return 0
        if choice == "1":
            refresh_screen()
            query_ip_details(port)
            continue
        if choice == "2":
            refresh_screen()
            block_by_ip(port)
            continue
        if choice == "3":
            refresh_screen()
            unblock_by_ip(port)
            continue
        if choice == "4":
            refresh_screen()
            new_source_notify_menu(port)
            continue

        print("无效选项")


def wait_return():
    while True:
        selected = input("0 返回上一级菜单：").strip()
        if selected == "0":
            return
        print("无效选项")


def query_ip_details(port):
    print_summary(port)
    wait_return()


def block_by_ip(port):
    while True:
        details = get_visible_ip_details(port)
        if not details:
            print("当前没有可封禁的公网 IP")
            wait_return()
            return

        sorted_ips = [ip for ip, _detail in sorted_ip_details(details)]
        for line in format_block_menu_lines(details):
            print(line)

        selected = input("输入要封禁的序号，0 返回上一级菜单：").strip()
        if selected == "0":
            return
        if not selected.isdigit() or int(selected) < 1 or int(selected) > len(sorted_ips):
            print("无效序号")
            wait_return()
            refresh_screen()
            continue

        ip = sorted_ips[int(selected) - 1]
        _ok, message = run_block_commands(ip, port)
        print(message)
        time.sleep(1)
        refresh_screen()


def unblock_by_ip(port):
    while True:
        blocked_entries = get_blocked_ip_entries(port)
        if not blocked_entries:
            print("当前没有这个 Snell 端口的封禁 IP")
            wait_return()
            return

        active_details = get_active_ip_details(port)
        sorted_ips = sorted(blocked_entries)
        for index, ip in enumerate(sorted_ips, start=1):
            label = get_blocked_ip_label(ip, active_details)
            protocols = "/".join(blocked_entries[ip].get("protocols", []))
            print(f"{index}. {label} {ip} 已封禁协议：{protocols}")

        selected = input("输入要解除封禁的序号，0 返回上一级菜单：").strip()
        if selected == "0":
            return
        if not selected.isdigit() or int(selected) < 1 or int(selected) > len(sorted_ips):
            print("无效序号")
            wait_return()
            refresh_screen()
            continue

        ip = sorted_ips[int(selected) - 1]
        ok, message = run_unblock_commands(blocked_entries[ip])
        if ok:
            print(message + "：" + ip)
        else:
            print(message)
        time.sleep(1)
        refresh_screen()


def parse_scan_interval(value):
    value = value.strip()
    if not value:
        return 60
    if not value.isdigit() or int(value) <= 0:
        return None
    return int(value)


def new_source_notify_menu(port):
    while True:
        print()
        print("新来源自动通知")
        print()
        print("当前状态：" + ("已开启" if is_monitor_enabled() else "已关闭"))
        print()
        print("1. 开启自动扫描")
        print("2. 关闭自动扫描")
        print("0. 返回")
        choice = input("请选择：").strip().lower()

        if choice == "0":
            return
        if choice == "1":
            server_name = input("请输入服务器名称：").strip()
            bot_token = input("请输入 Telegram Bot Token：").strip()
            chat_id = input("请输入 Telegram Chat ID：").strip()
            interval = parse_scan_interval(input("请输入扫描间隔秒数，默认 60："))
            if not server_name or not bot_token or not chat_id or interval is None:
                print("输入无效")
                wait_return()
                refresh_screen()
                continue

            ok, message = enable_new_source_monitor(port, server_name, bot_token, chat_id, interval)
            print(message)
            time.sleep(1)
            refresh_screen()
            continue
        if choice == "2":
            _ok, message = disable_monitor_timer()
            print(message)
            time.sleep(1)
            refresh_screen()
            continue

        print("无效选项")
        wait_return()
        refresh_screen()

